{
  "expo": {
    "name": "SEE ME",
    "slug": "seeme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seeme",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SEE ME needs your location to verify check-ins at places",
        "NSLocationAlwaysUsageDescription": "SEE ME uses your location to show nearby places",
        "NSCameraUsageDescription": "Scan QR codes to check-in at venues"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d0415"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d0415"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SEE ME uses your location to verify check-ins and show nearby activity."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Scan QR codes to check-in at partner venues"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
