{
  "expo": {
    "name": "SEE ME",
    "slug": "seeme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seeme",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.seeme.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SEE ME needs your location to verify check-ins at places",
        "NSLocationAlwaysUsageDescription": "SEE ME uses your location to show nearby places and activity",
        "NSCameraUsageDescription": "Take selfies to share in chat or scan QR codes to check-in",
        "NSPhotoLibraryUsageDescription": "Share photos from your gallery in chat",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.seemeapp.android",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d0415"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d0415"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SEE ME uses your location to verify check-ins and show nearby activity.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Take selfies to share in chat or scan QR codes"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Share photos from your gallery in chat",
          "cameraPermission": "Take selfies to share in chat"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#F4C542"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
