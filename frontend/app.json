{
  "expo": {
    "name": "SEE ME",
    "slug": "seeme",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "seeme",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "owner": "thelively32",
    "extra": {
      "eas": {
        "projectId": "98ae5773-f5c4-484c-bcc5-6d8cbdd8e85c"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luisgarcia.seeme",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SEE ME needs your location to verify check-ins at places",
        "NSLocationAlwaysUsageDescription": "SEE ME uses your location to show nearby places and activity",
        "NSCameraUsageDescription": "Take selfies to share in chat or scan QR codes to check-in",
        "NSPhotoLibraryUsageDescription": "Share photos from your gallery in chat",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.seemeapp.android",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d0415"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.1",
            "buildSettings": {
              "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES"
            }
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d0415"
        }
      ],
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}